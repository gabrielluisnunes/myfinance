{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".expo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["EXPO_PUBLIC_API_URL"]
    },
    "lint": {},
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["generated/**"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
